{
  "Jwt": {
    "Secret": "PLACEHOLDER",
    "Issuer": "flowStack.AuthService",
    "Audience": "FlowStack.Services"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-register": {
        "ClusterId": "auth-service",
        "Match": { "Path": "/api/auth/register" }
      },
      "auth-login": {
        "ClusterId": "auth-service",
        "Match": { "Path": "/api/auth/login" }
      },
      "auth-refresh": {
        "ClusterId": "auth-service",
        "Match": { "Path": "/api/auth/refresh" }
      },
      "auth-validate": {
        "ClusterId": "auth-service",
        "Match": { "Path": "/api/auth/validate" }
      },
      "oauth-google": {
        "ClusterId": "auth-service",
        "Match": { "Path": "/api/oauth/google/{**catch-all}" }
      },
      "oauth-github": {
        "ClusterId": "auth-service",
        "Match": { "Path": "/api/oauth/github/{**catch-all}" }
      },

      "auth-authenticated": {
        "ClusterId": "auth-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },

      "workspace-public": {
        "ClusterId": "workspace-service",
        "Match": { "Path": "/api/workspaces/public" }
      },
      "workspace-check": {
        "ClusterId": "workspace-service",
        "Match": {
          "Path": "/api/workspaces/{workspaceId}/members/{userId}/check"
        }
      },
      "workspace-all": {
        "ClusterId": "workspace-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/workspaces/{**catch-all}" }
      },

      "board-access-check": {
        "ClusterId": "board-service",
        "Match": { "Path": "/api/boards/{boardId}/access/{userId}" }
      },
      "board-all": {
        "ClusterId": "board-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/boards/{**catch-all}" }
      },

      "list-all": {
        "ClusterId": "list-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/lists/{**catch-all}" }
      },

      "card-all": {
        "ClusterId": "task-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/cards/{**catch-all}" }
      },

      "comment-all": {
        "ClusterId": "comment-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/comments/{**catch-all}" }
      },
      "attachment-all": {
        "ClusterId": "comment-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/attachments/{**catch-all}" }
      },
      "card-comments": {
        "ClusterId": "comment-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/cards/{cardId}/comments/{**catch-all}" }
      },
      "card-attachments": {
        "ClusterId": "comment-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/cards/{cardId}/attachments/{**catch-all}" }
      },

      "label-all": {
        "ClusterId": "label-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/labels/{**catch-all}" }
      },
      "board-labels": {
        "ClusterId": "label-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/boards/{boardId}/labels" }
      },
      "card-labels": {
        "ClusterId": "label-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/cards/{cardId}/labels/{**catch-all}" }
      },
      "checklist-all": {
        "ClusterId": "label-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/checklists/{**catch-all}" }
      },
      "checklist-items": {
        "ClusterId": "label-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/items/{**catch-all}" }
      },
      "card-checklists": {
        "ClusterId": "label-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/cards/{cardId}/checklists" }
      },
      "card-progress": {
        "ClusterId": "label-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/cards/{cardId}/progress" }
      },

      "notification-all": {
        "ClusterId": "notification-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "notification-root": {
        "ClusterId": "notification-service",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/notifications" }
      },

      "health-auth": {
        "ClusterId": "auth-service",
        "Match": { "Path": "/health/auth" },
        "Transforms": [{ "PathRemovePrefix": "/health" }]
      },
      "health-workspace": {
        "ClusterId": "workspace-service",
        "Match": { "Path": "/health/workspace" },
        "Transforms": [{ "PathRemovePrefix": "/health" }]
      },
      "health-board": {
        "ClusterId": "board-service",
        "Match": { "Path": "/health/board" },
        "Transforms": [{ "PathRemovePrefix": "/health" }]
      },
      "health-list": {
        "ClusterId": "list-service",
        "Match": { "Path": "/health/list" },
        "Transforms": [{ "PathRemovePrefix": "/health" }]
      },
      "health-task": {
        "ClusterId": "task-service",
        "Match": { "Path": "/health/task" },
        "Transforms": [{ "PathRemovePrefix": "/health" }]
      },
      "health-comment": {
        "ClusterId": "comment-service",
        "Match": { "Path": "/health/comment" },
        "Transforms": [{ "PathRemovePrefix": "/health" }]
      },
      "health-label": {
        "ClusterId": "label-service",
        "Match": { "Path": "/health/label" },
        "Transforms": [{ "PathRemovePrefix": "/health" }]
      },
      "health-notification": {
        "ClusterId": "notification-service",
        "Match": { "Path": "/health/notification" },
        "Transforms": [{ "PathRemovePrefix": "/health" }]
      }
    },

    "Clusters": {
      "auth-service": {
        "Destinations": {
          "primary": {
            "Address": "https://flowstack-auth-service.onrender.com"
          }
        }
      },
      "workspace-service": {
        "Destinations": {
          "primary": {
            "Address": "https://flowstack-workspace-service.onrender.com"
          }
        }
      },
      "board-service": {
        "Destinations": {
          "primary": {
            "Address": "https://flowstack-board-service.onrender.com"
          }
        }
      },
      "list-service": {
        "Destinations": {
          "primary": {
            "Address": "https://flowstack-list-service.onrender.com"
          }
        }
      },
      "task-service": {
        "Destinations": {
          "primary": {
            "Address": "https://flowstack-task-service.onrender.com"
          }
        }
      },
      "comment-service": {
        "Destinations": {
          "primary": {
            "Address": "https://flowstack-comment-service.onrender.com"
          }
        }
      },
      "label-service": {
        "Destinations": {
          "primary": {
            "Address": "https://flowstack-label-service.onrender.com"
          }
        }
      },
      "notification-service": {
        "Destinations": {
          "primary": {
            "Address": "https://flowstack-notification-service.onrender.com"
          }
        }
      }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
