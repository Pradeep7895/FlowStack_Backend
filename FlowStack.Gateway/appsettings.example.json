{
  "Jwt": {
    "Secret": "YOUR_JWT_SECRET_MIN_32_CHARS",
    "Issuer": "flowStack.AuthService",
    "Audience": "FlowStack.Services"
  },

  "ReverseProxy": {
    "Routes": {
    },
    "Clusters": {
      "auth-service":         { "Destinations": { "primary": { "Address": "http://localhost:5001" } } },
      "workspace-service":    { "Destinations": { "primary": { "Address": "http://localhost:5002" } } },
      "board-service":        { "Destinations": { "primary": { "Address": "http://localhost:5003" } } },
      "list-service":         { "Destinations": { "primary": { "Address": "http://localhost:5004" } } },
      "task-service":         { "Destinations": { "primary": { "Address": "http://localhost:5005" } } },
      "comment-service":      { "Destinations": { "primary": { "Address": "http://localhost:5006" } } },
      "label-service":        { "Destinations": { "primary": { "Address": "http://localhost:5007" } } },
      "notification-service": { "Destinations": { "primary": { "Address": "http://localhost:5008" } } }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}